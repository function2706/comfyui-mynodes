{
  "ruff.enable": true,
  "ruff.format.enable": true,
  "ruff.lint.enable": true,
  "ruff.logLevel": "error",
  "editor.codeActionsOnSave": {
    "source.fixAll": "explicit",
    "source.organizeImports": "explicit"
  },
  "editor.formatOnSave": true,
  "python.formatting.provider": "none",
  "autoDocstring.generateDocstringOnEnter": true,
  "autoDocstring.docstringFormat": "google",
  "autoDocstring.includeName": true,
  "autoDocstring.includeExtendedSummary": false,
  "autoDocstring.startOnNewLine": true,
  "editor.semanticHighlighting.enabled": true,
  "editor.semanticTokenColorCustomizations": {
    "rules": {
      "selfParameter": "#968186", // self
      "clsParameter": "#968186", // cls
      "class": "#4ec9b0", // クラス名
      "class.decorator": "#4ec969", // @property など
      "class.typeHint": "#4ec9b0", // 型ヒント
      "enum": "#4ec9b0", // enum
      "method": "#e2c691", // メソッド
      "function": "#dcdcaa", // 関数名
      "function.decorator": "#e6e67e", // @abstractmethod など
      "magicFunction": "#e2c691", // __init__ など
      "parameter": "#9a9a9a", // 関数引数
      "property": "#93ace4", // メンバ変数
      "variable": "#9cdcfe", // 変数
      "variable.declaration": {
        "foreground": "#9cdcfe",
        "fontStyle": "italic"
      }, // 宣言された変数
      "variable.callable": "#e2c691", // Callable な変数
      "variable.classMember": "#93ace4", // メンバ変数
      "module": "#f38faa", // from (namespace)
      "builtinConstant": "#3ab7fa" // True, False, None
    }
  },
  "editor.tokenColorCustomizations": {
    "textMateRules": [
      {
        /* 関数への引数代入時の左辺 */
        "scope": "variable.parameter.function-call.python",
        "settings": {
          "fontStyle": "italic"
        }
      },
      {
        /* 文字列系 */
        "scope": ["string.quoted"],
        "settings": {
          "foreground": "#ce9178"
        }
      },
      {
        /* コメントライン('#' から始まるコメント) */
        "scope": ["comment.line", "punctuation.definition.comment"],
        "settings": {
          "foreground": "#6a9955"
        }
      },
      {
        /* def, class 等 */
        "scope": [
          "storage.type.type.python",
          "storage.type.function.python",
          "storage.type.class.python",
          "storage.type.function.lambda.python"
        ],
        "settings": {
          "foreground": "#569cd6"
        }
      },
      {
        /* @decorator */
        "scope": ["punctuation.definition.decorator.python"],
        "settings": {
          "foreground": "#e6e67e"
        }
      }
    ]
  },
  "[markdown]": {
    "editor.formatOnSave": true,
    "editor.formatOnPaste": true,
    "editor.defaultFormatter": "yzhang.markdown-all-in-one"
  }
}
